.venv/
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# Fichiers temporaires et archives locales
temp/
archive/
*.log

# Données lourdes ou reconstruites localement
data/raw/
data/interim/
data/processed/

# Rapports locaux générés automatiquement
reports/figures/

# Par défaut, on ignore toutes les sorties expérimentales et runtime
outputs/**

